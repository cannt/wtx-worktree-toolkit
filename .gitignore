.DS_Store
*.swp
*.swo
*~
docs/project-scan-report.json

# Local Claude Code / BMAD tooling — vendored in the working dir, not part of
# the wtx tool itself. Kept on disk but not tracked.
.claude/skills/
.agents/
_bmad/

# iCloud Drive conflict-copy duplicates ("name 2.ext", "dir 2/")
* 2.*
* 2

# Personal / local config — never commit real org, Jira keys, or tokens.
# wtx.example.toml is the tracked template; the real config is wtx.toml.
/wtx.toml
wtx.local.toml
.worktree-projects

# Secrets and environment files (put rotated tokens here, never in tracked files)
.env
*.env
*.secret
secrets.*

# npm wrapper build artifact — bootstrap.sh is copied in by `prepack` at publish
# time from the repo root; never track the copy.
npm/bootstrap.sh
npm/node_modules/

# graphify knowledge-graph artifacts — generated locally, rebuilt on commit by
# the git post-commit hook. Not part of the wtx tool; kept out of git and iCloud.
graphify-out/
.claude/.story-automator-active
